# Hooten Young Dashboard — environment variables
#
# IMPORTANT:
#   - CRA exposes any var prefixed with REACT_APP_* to the browser bundle.
#   - Anything in REACT_APP_* is PUBLIC. Never put secrets there.
#   - True secrets (DB URLs, server-side API keys) must live behind a backend,
#     not in this file.
#
# How to use:
#   1. Copy this file to `.env.local` (local dev) — `.env.local` is gitignored.
#   2. In production, set the same vars in the GCP build / Cloud Run config.
#   3. Never commit real values.
#
# ---------------------------------------------------------------
# App configuration (browser-exposed)
# ---------------------------------------------------------------

# Base URL of the backend API that proxies the shared Postgres.
# Backend shape TBD — see CLAUDE.md "Open question: backend shape".
# REACT_APP_API_BASE_URL=http://localhost:8080

# App environment shown in the UI corner: local | staging | production
REACT_APP_ENV=local

# ---------------------------------------------------------------
# Tooling / MCP (NOT browser-exposed — used by .mcp.json only)
# ---------------------------------------------------------------

# GitHub personal access token for the github MCP server (scopes: repo, read:org).
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Shared Postgres connection for the postgres MCP server (read-only DSN preferred
# for dashboard work — schema is owned by hooten-young-analytics).
# Coordinate with the analytics repo owner before changing schema.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
