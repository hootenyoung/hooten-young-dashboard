# Dependencies
node_modules/
.pnp
.pnp.js

# CRA build output
build/

# Production
dist/

# Environment files — never commit local secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Claude Code — local-only settings + session logs
.claude/settings.local.json
.claude/session.log

# GCP service-account keys — never commit
*-service-account*.json
gcp-key*.json
service-account*.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Local data dumps (never commit uploaded sales reports)
.tmp/
uploads/
*.xlsx
*.xls
*.csv
!.claude/**/*.csv
!docs/**/*.csv
!tests/**/fixtures/**/*.csv
!tests/**/fixtures/**/*.xlsx
